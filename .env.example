# Webhooks de notificação (Discord e Slack)
# Obtenha o webhook ao criar um canal/bot em Discord ou Slack
DISCORD_WEBHOOK_LINKA=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN
SLACK_WEBHOOK_LINKA=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Cloudflare Workers — configuração de ambiente
# Utilize para dev local com wrangler dev (integrations/)
ADMIN_SECRET=your_admin_secret_here_do_not_commit
INGEST_KEY=your_ingest_key_here_do_not_commit
ADMIN_AUTH_PEPPER=your_pepper_here_do_not_commit

# Firebase (copie de firebase console se necessário)
FIREBASE_PROJECT_ID=signallq-app
FIREBASE_CLIENT_EMAIL=your-service-account@signallq-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_GA4_PROPERTY_ID=your_ga4_id

# Outros segredos locais
API_KEY=your_key_here
