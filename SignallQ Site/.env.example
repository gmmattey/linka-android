# Site público SignallQ — variáveis de build (Vite). Nenhum valor sensível
# aqui: a INGEST_KEY de telemetria vive só como secret do Cloudflare Pages
# (functions/api/track.ts), nunca em variável VITE_* (essas vão pro bundle
# client-side, visíveis via "ver código-fonte").

# Link oficial de distribuição Beta do app SignallQ (Firebase App Distribution
# ou Play Console). Já tem default real no código (config.ts) apontando pra
# Play Store — só preencha aqui se precisar sobrescrever (ex.: trocar pra link
# de Firebase App Distribution num ambiente de teste).
VITE_SIGNALLQ_BETA_DOWNLOAD_URL=

# Google AdSense — deixe vazio para manter o AdSlot como placeholder reservado.
VITE_ADSENSE_PUBLISHER_ID=
VITE_ADSENSE_SLOT_RESULT=

# Motor de medição real — default já aponta para speed.cloudflare.com/__down|__up.
# Só sobrescreva se for trocar por um endpoint próprio.
VITE_SPEEDTEST_DOWNLOAD_URL=
VITE_SPEEDTEST_UPLOAD_URL=
VITE_SPEEDTEST_SERVER_LABEL=
