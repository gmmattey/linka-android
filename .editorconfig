root = true

[*.kt]
indent_style = space
indent_size = 4
max_line_length = 160
ktlint_standard_no-wildcard-imports = disabled

# Composable functions use PascalCase convention per Compose guidelines
# https://developer.android.com/jetpack/compose/style-guide#naming-composable-functions
[app/src/main/kotlin/io/linka/app/kotlin/ui/**/*.kt]
ktlint_standard_function-naming = disabled

# Issue #29 — residual manual violations to be fixed in follow-up PR
# These 4 rules have non-auto-correctable violations that require code changes
[app/src/main/kotlin/io/linka/app/kotlin/**/*.kt]
ktlint_standard_property-naming = disabled
ktlint_standard_max-line-length = disabled
ktlint_standard_enum-entry-name-case = disabled
ktlint_standard_no-empty-file = disabled

# Gradle build script pre-existing formatting violations
[*.gradle.kts]
ktlint_standard_no-multi-spaces = disabled
ktlint_standard_chain-method-continuation = disabled
ktlint_standard_comma-spacing = disabled
ktlint_standard_multiline-expression-wrapping = disabled
