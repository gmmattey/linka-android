#!/usr/bin/env bash
# Guardrail versionado: impede commit que cruza stacks do monorepo
# (despejo de worktree removida na branch errada).
# Override consciente: COMMIT_ALLOW_CROSS_STACK=1 git commit ...
set -euo pipefail

if [ "${COMMIT_ALLOW_CROSS_STACK:-0}" = "1" ]; then
  exit 0
fi

files=$(git diff --cached --name-only)
[ -z "$files" ] && exit 0

stacks=$(printf '%s\n' "$files" | awk '
  /^android\//          { print "android"; next }
  /^SignallQ Admin\//   { print "admin"; next }
  /^integrations\//     { print "integrations"; next }
' | sort -u)

count=$(printf '%s\n' "$stacks" | grep -c . || true)

if [ "$count" -gt 1 ]; then
  echo "BLOQUEADO: commit cruzando stacks -> $(echo $stacks | tr '\n' ' ')" >&2
  echo "Cada stack vai em sua branch/commit. Isso costuma ser despejo de worktree." >&2
  echo "Se for intencional: COMMIT_ALLOW_CROSS_STACK=1 git commit ..." >&2
  exit 1
fi

exit 0
