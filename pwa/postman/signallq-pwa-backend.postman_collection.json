{
  "info": {
    "name": "SignallQ PWA Backend",
    "_postman_id": "7cf39095-7f43-47b0-aee1-7c0b6889b8f3",
    "description": "Smoke tests for SignallQ PWA Cloudflare Pages Functions. No secrets are stored in this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "SpeedTest - latency",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/speedtest/latency?cacheBust={{$timestamp}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('json has HTTP timing limitation', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.ok).to.eql(true);",
              "  pm.expect(json.method).to.eql('http_timing');",
              "  pm.expect(json.limitations).to.include('http_latency_not_icmp_ping');",
              "});",
              "pm.test('no-store cache header', function () {",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.include('no-store');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "SpeedTest - download",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/speedtest/download?bytes=65536&cacheBust={{$timestamp}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('byte metadata returned', function () {",
              "  pm.expect(pm.response.headers.get('X-SignallQ-Speedtest-Bytes')).to.eql('65536');",
              "});",
              "pm.test('no-store cache header', function () {",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.include('no-store');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "SpeedTest - upload ok",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/octet-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "signallq-pwa-upload-smoke"
        },
        "url": "{{baseUrl}}/api/speedtest/upload?cacheBust={{$timestamp}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('json has received bytes', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.ok).to.eql(true);",
              "  pm.expect(json.receivedBytes).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "SpeedTest - upload too large",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.body.update('x'.repeat(4194305));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 413', function () { pm.response.to.have.status(413); });",
              "pm.test('json error response', function () {",
              "  pm.expect(pm.response.json()).to.have.property('error');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/octet-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "too-large-body-generated-in-prerequest"
        },
        "url": "{{baseUrl}}/api/speedtest/upload?cacheBust={{$timestamp}}"
      }
    },
    {
      "name": "Admin Ingest - invalid envelope",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"kind\": \"diagnostic\"\n}"
        },
        "url": "{{baseUrl}}/api/admin/ingest"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 400', function () { pm.response.to.have.status(400); });",
              "pm.test('json error response', function () {",
              "  pm.expect(pm.response.json()).to.have.property('error');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Ingest - missing server env",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"kind\": \"diagnostic\",\n  \"payload\": {\n    \"id\": \"diag_postman_missing_env\",\n    \"environment\": \"development\",\n    \"dist_channel\": \"pwa\",\n    \"build_type\": \"web\",\n    \"version_code\": 1,\n    \"device_id\": \"pwa-postman\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/admin/ingest"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 503 when local Pages env is not configured', function () {",
              "  pm.response.to.have.status(503);",
              "});",
              "pm.test('json error response', function () {",
              "  pm.expect(pm.response.json()).to.have.property('error');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "AI Diagnosis - missing server env",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"schemaVersion\": \"pwa_foundation_v1\",\n  \"source\": \"pwa\",\n  \"connectionType\": \"unknown\",\n  \"metricasAtuais\": {\n    \"downloadMbps\": null,\n    \"uploadMbps\": null,\n    \"latenciaMs\": null\n  }\n}"
        },
        "url": "{{baseUrl}}/api/ai/diagnostico-conexao"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 503 when local Pages env is not configured', function () {",
              "  pm.response.to.have.status(503);",
              "});",
              "pm.test('json error response', function () {",
              "  pm.expect(pm.response.json()).to.have.property('error');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
