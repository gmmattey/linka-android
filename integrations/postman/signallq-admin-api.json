    {
      "name": "Feature Flags",
      "item": [
        {
          "name": "Public Flags",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/feature-flags",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "feature-flags"
              ]
            }
          },
          "description": "Feature flags públicas (sem autenticação). Usado pelo app."
        },
        {
          "name": "Admin Flags",
          "request": {
