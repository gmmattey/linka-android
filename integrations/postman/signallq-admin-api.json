    {
      "name": "Ingest",
      "item": [
        {
          "name": "Diagnostic",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ingestKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"deviceId\": \"d1\", \"speed\": 45.5}"
            },
            "url": {
              "raw": "{{baseUrl}}/ingest/diagnostic",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ingest",
                "diagnostic"
              ]
            }
          },
          "description": "Ingere dados de diagnóstico do app (requer Bearer INGEST_KEY)"
        },
        {
          "name": "AI Usage",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ingestKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"diagnosticId\": \"d1\", \"tokens\": 256}"
            },
            "url": {
              "raw": "{{baseUrl}}/ingest/ai-usage",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ingest",
                "ai-usage"
              ]
            }
          },
          "description": "Ingere dados de uso de IA - tokens, custo, latência"
        }
      ],
      "description": "Endpoints de ingest de dados - requerem Bearer token INGEST_KEY separado"
    },
    {
