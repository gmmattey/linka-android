{
  "info": {
    "name": "SignallQ Admin Worker API",
    "description": "Collection completa para testes e integração com o Admin Worker da SignallQ",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "signallq-admin-api-v1",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{adminEmail}}\", \"password\": \"{{adminPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "auth",
                "login"
              ]
            }
          },
          "description": "Autentica um usuário admin. Retorna cookie de sessão httpOnly que o Postman gerencia automaticamente."
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "auth",
                "me"
              ]
            }
          },
          "description": "Retorna dados do usuário autenticado (requer cookie de sessão)."
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"currentPassword\": \"{{adminPassword}}\", \"newPassword\": \"nova_senha\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/auth/password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "auth",
                "password"
              ]
            }
          },
          "description": "Altera a senha do usuário autenticado (requer sessão válida)."
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"novo@example.com\", \"password\": \"senha\", \"role\": \"admin\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/auth/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "auth",
                "users"
              ]
            }
          },
          "description": "Cria novo usuário admin (requer role admin na sessão)."
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "auth",
                "logout"
              ]
            }
          },
          "description": "Faz logout e invalida o cookie de sessão."
        }
      ],
      "description": "Endpoints de autenticação via cookie de sessão. Login retorna cookie httpOnly automaticamente gerenciado pelo Postman."
    },
