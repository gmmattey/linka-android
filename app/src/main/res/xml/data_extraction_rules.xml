<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules disableIfNoEncryptionCapabilities="true">
    <cloud-backup>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="database" path="linkaKotlin.db"/>
        <exclude domain="database" path="linkaKotlin.db-shm"/>
        <exclude domain="database" path="linkaKotlin.db-wal"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="database" path="linkaKotlin.db"/>
    </device-transfer>
</data-extraction-rules>
