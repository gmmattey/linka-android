# =============================================================================
# SignallQ Admin Panel — Variáveis de ambiente
# Copie para .env.local e preencha os valores reais.
# NUNCA commitar .env.local no git.
# =============================================================================
# O painel NÃO se conecta ao Firebase diretamente.
# Todos os dados (Firebase Analytics, Crashlytics, Diagnósticos, Custo IA)
# chegam pelo Cloudflare Admin Worker — única fonte de dados do painel.
# =============================================================================

# --- Modo de operação ---
# true  = dados mockados locais (desenvolvimento sem backend)
# false = chamadas reais ao Cloudflare Admin Worker
VITE_ENABLE_MOCKS=true

# --- Cloudflare Admin Worker ---
# URL do worker após deploy (substitui esquilo-invest-web).
# Deixar vazio enquanto VITE_ENABLE_MOCKS=true.
# Preencher após: cd integrations/cloudflare/signallq-admin-worker && npx wrangler deploy
VITE_ADMIN_API_BASE_URL=https://esquilo-invest-web.giammattey-luiz.workers.dev

# Bearer token para autenticar no worker.
# Deve ser idêntico ao secret configurado com:
#   npx wrangler secret put ADMIN_SECRET
VITE_ADMIN_API_SECRET=

# --- Geral ---
VITE_APP_ENV=production
VITE_API_TIMEOUT_MS=15000
